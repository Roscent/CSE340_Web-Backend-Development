<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= organizationDetails.name %>
        </h2>
        <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %> logo">

        <p><strong>Description:</strong>
            <%= organizationDetails.description %>
        </p>
        <p><strong>Contact Email:</strong> <a href="mailto:<%= organizationDetails.contact_email %>">
                <%= organizationDetails.contact_email %>
            </a></p>

        <% if (user && user.role_name==='admin' ) { %>
            <p><a href="/edit-organization/<%= organizationDetails.organization_id %>">Edit Organization Details</a></p>
        <% } %>

        <h3>Service Projects</h3>
        <% if (projects && projects.length> 0) { %>
            <ul>
                <% projects.forEach(project=> { %>
                    <li>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                    </li>
                <% }) %>
            </ul>
            <% } else { %>
                <p>No service projects currently listed for this organization.</p>
            <% } %>

            <p><a href="/organizations">← Back to all organizations</a></p>
    </main>
    <%- include('partials/footer') %>