<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <p>Browse service projects by category:</p>

        <% if (user && user.role_name==='admin' ) { %>
            <p><a href="/new-category" class="btn btn-primary">+ Add New Category</a></p>
        <% } %>

        <% if (categories && categories.length> 0) { %>
            <ul>
                <% categories.forEach(category=> { %>
                    <li>
                        <a href="/category/<%= category.category_id %>">
                            <%= category.name %>
                        </a>
                        <% if (user && user.role_name==='admin' ) { %>
                            <a href="/edit-category/<%= category.category_id %>" class="edit-link">(Edit)</a>
                        <% } %>
                    </li>
                <% }); %>
            </ul>
            <% } else { %>
                <p>No categories found. <a href="/new-category">Create the first category</a>.</p>
            <% } %>
    </main>
    <%- include('partials/footer') %>