<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <p>Here are our upcoming community service opportunities:</p>

        <% if (projects && projects.length> 0) { %>
            <ul>
                <% projects.forEach(project=> { %>
                    <li>
                        <strong>
                            <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                        </strong>
                        (Organized by:<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
                        - <em>
                            <%= new Date(project.date).toDateString() %>
                        </em>
                    </li>
                <% }); %>
            </ul>
            <% } else { %>
                <p>No upcoming service projects listed at this moment. Check back later!</p>
            <% } %>

        <% if (user && user.role_name==='admin' ) { %>
            <p><a href="/new-project">Add a New Service Project</a></p>
        <% } %>
    </main>

<%- include('partials/footer') %>