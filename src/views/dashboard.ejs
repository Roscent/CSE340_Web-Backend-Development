<%- include('partials/header') %>

    <main>
        <h1><%= title %></h1>

        <h2>Dashboard</h2>
        <p>Name: <%= name %></p>
        <p>Username: <%= email %></p>

        <% if (user && user.role_name==='admin' ) { %>
            <div class="admin-section" style="margin-top: 30px; padding: 15px; background-color: #f5f5f5; border-radius: 5px;">
                <h3>Admin Actions</h3>
                <ul>
                    <li><a href="/users">View All Users</a></li>
                </ul>
            </div>
        <% } %>
    </main>

    <%- include('partials/footer') %>